{{!
    Template for the designed PDF report.
}}
<style>
  @page {
    size: A4;
    margin: 28mm 12mm 15mm 12mm;
    header: html_runhdr;
    footer: html_pgfooter;
  }
  @page :first {
    margin-top: 14mm;
    header: _blank;
  }
  html, body { font-family: "dejavusans", sans-serif; font-size: 9.5pt; color: #1a1a1a; line-height: 1.42; }
  table { border-collapse: collapse; border-spacing: 0; }
  
  .hdr-table { width: 100%; border-bottom: 1.2pt solid {{accent_color}}; padding-bottom: 4mm; margin-bottom: 6mm; }
  .hdr-title { text-align: center; font-size: 12pt; color: {{accent_color}}; font-weight: bold; letter-spacing: -0.2px; }
  .hdr-meta { text-align: right; font-size: 8pt; color: #7a7a7a; line-height: 1.4; }
  .hdr-meta strong { color: #1a1a1a; font-size: 9pt; display: block; text-transform: uppercase; }
  
  .hero-table { width: 100%; border: 0.5pt solid #dcdcdc; border-radius: 1mm; border-collapse: collapse; margin-bottom: 6mm; }
  .hero-table td { border-right: 0.5pt solid #dcdcdc; vertical-align: middle; padding: 4mm 5mm; }
  .hero-table td:last-child { border-right: none; }
  
  .hcell-status { width: 40mm; text-align: center; background: #e8f3ec; }
  .hcell-status.is-pending { background: #e6f0fa; }
  .hcell-status.is-fail { background: #fcebe9; }
  
  .hicon { display: block; width: 10mm; height: 10mm; line-height: 10mm; margin: 0 auto 1.5mm; border: 1pt solid #1f7a3f; border-radius: 50%; background: white; color: #1f7a3f; font-size: 13pt; font-weight: bold; }
  .is-fail .hicon { border-color: #b42318; color: #b42318; }
  .is-pending .hicon { border-color: #1e6fb0; color: #1e6fb0; }
  
  .hbadge { font-size: 11pt; font-weight: bold; text-transform: uppercase; letter-spacing: 0.5px; color: #1f7a3f; }
  .is-fail .hbadge { color: #b42318; }
  .is-pending .hbadge { color: #1e6fb0; }
  .hsub { font-size: 7.5pt; color: #7a7a7a; text-transform: uppercase; margin-top: 1mm; }
  
  .hcell-big { font-size: 22pt; font-weight: 300; letter-spacing: -0.5px; }
  .hcell-pct { font-size: 11pt; color: #4a4a4a; margin-left: 1mm; font-weight: 500; }
  
  .sb-table { border-spacing: 1.2mm; border-collapse: separate; margin: 1mm 0 0 -1.2mm; }
  .sb-dot { width: 8.5mm; height: 5.5mm; border-radius: 0.8mm; font-size: 7.5pt; font-weight: bold; text-align: center; line-height: 1; padding: 0; }
  .ok { background: #1f7a3f; color: white; }
  .wrong { background: white; color: #b42318; border: 0.6pt solid #b42318; }
  .partial { background: #c48a00; color: #5a3f00; }
  .pending { background: #1e6fb0; color: white; }

  .qcard { margin-bottom: 3mm; padding: 3mm 4mm; background: #fcfcfd; border: 0.4pt solid #dcdcdc; border-left: 1.5mm solid #1f7a3f; }
  .qcard.is-wrong { background: #fdf9f8; border-left-style: double; border-left-color: #b42318; }
  .qcard.is-partial { background: #fdfaf4; border-left-style: dashed; border-left-color: #c48a00; }
  .qcard.is-pending { background: #e6f0fa; border-left-style: dotted; border-left-color: #1e6fb0; }
  
  .m-hdr { font-size: 7.5pt; text-transform: uppercase; letter-spacing: 0.9px; color: {{accent_color}}; font-weight: bold; padding-bottom: 1mm; border-bottom: 0.5pt solid #dcdcdc; margin-bottom: 2mm; }
  .m-row { font-size: 9pt; padding: 0.8mm 0; }
  .m-lbl { color: #7a7a7a; width: 35mm; }
  .m-val { font-weight: 500; text-align: right; }
</style>

{{#attempts}}
<div class="attempt-container">
    <table class="hdr-table">
        <tr>
            <td width="35%">{{{logo_html}}}</td>
            <td class="hdr-title">QUIZ-AUSWERTUNG</td>
            <td class="hdr-meta"><strong>VERSUCH #{{attempt_no}}</strong><br>{{date_finished}}</td>
        </tr>
    </table>

    <table class="hero-table">
        <tr>
            <td class="hcell-status {{#is_pending}}is-pending{{/is_pending}} {{^passed}}is-fail{{/passed}}">
                <div class="hicon">{{#passed}}✓{{/passed}}{{^passed}}✗{{/passed}}</div>
                <div class="hbadge">{{status_label}}</div>
                <div class="hsub">{{#is_pending}}{{pending_count}} offen{{/is_pending}}{{^is_pending}}Status{{/is_pending}}</div>
            </td>
            <td width="45%">
                <div class="hcell-big">{{grade}} <span style="color: #7a7a7a;">/</span> {{max_grade}} <span class="hcell-pct">· {{percentage}}%</span></div>
                <div class="hsub">Erreichte Punkte</div>
            </td>
            <td>
                <div style="font-weight: bold;">{{quiz_name}}</div>
                <div style="font-size: 8pt; color: #7a7a7a;">Kurs: {{course_name}}</div>
            </td>
        </tr>
    </table>

    <table width="100%" style="border-collapse: collapse;">
        <tr>
            <td width="50%" valign="top">
                <div class="m-hdr">TEILNEHMER/IN</div>
                <div style="font-weight: bold;">{{learner_name}}</div>
                <div style="color: #7a7a7a; font-size: 8pt;">{{learner_email}}</div>
                <div style="color: #7a7a7a; font-size: 8pt; margin-top: 1mm;">Moodle-ID: {{learner_id}}</div>
                
                <div class="m-hdr" style="margin-top: 6mm;">VERSUCH</div>
                <table width="100%">
                    {{#show_duration}}<tr><td class="m-lbl">Dauer</td><td class="m-val">{{duration}}</td></tr>{{/show_duration}}
                    {{#show_passgrade}}<tr><td class="m-lbl">Bestehensgrenze</td><td class="m-val">{{gradepass}}</td></tr>{{/show_passgrade}}
                </table>
            </td>
            <td width="50%" valign="top" style="padding-left: 8mm;">
                <div class="m-hdr">FRAGEN-ÜBERSICHT</div>
                <table class="sb-table">
                    {{#slots_rows}}
                        <tr>
                            {{#row_slots}}<td class="sb-dot {{class}}">{{num}}</td>{{/row_slots}}
                        </tr>
                    {{/slots_rows}}
                </table>
                <div style="font-size: 7.5pt; color: #7a7a7a; margin-top: 3mm;">
                    richtig <strong>{{counts.correct}}</strong> · falsch <strong>{{counts.wrong}}</strong> · offen <strong>{{counts.pending}}</strong>
                </div>
            </td>
        </tr>
    </table>

    <div style="page-break-after: always;"></div>

    <h3 class="m-hdr" style="font-size: 10pt;">FRAGEN & ANTWORTEN</h3>
    {{#questions}}
        <div class="qcard {{#is_wrong}}is-wrong{{/is_wrong}} {{#is_partial}}is-partial{{/is_partial}} {{#is_pending}}is-pending{{/is_pending}}">
            <table width="100%">
                <tr>
                    <td style="font-weight: bold;"><span style="color: #7a7a7a; font-weight: 500;">Frage {{num}}</span> {{text}}</td>
                    <td align="right" width="20mm" style="font-weight: 500; font-size: 8.5pt;">{{score}} / {{max_score}}</td>
                </tr>
            </table>
            <table width="100%" style="margin-top: 3mm; font-size: 8.5pt;">
                <tr>
                    <td width="22mm" style="color: #7a7a7a; text-transform: uppercase; font-size: 7pt; font-weight: bold; vertical-align: top;">ANTWORT</td>
                    <td>{{{answer}}}</td>
                </tr>
            </table>
        </div>
    {{/questions}}
</div>
{{/attempts}}
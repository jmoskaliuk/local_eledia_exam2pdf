# .gitattributes — export-ignore Liste für git archive
# Alles hier aufgeführte landet NICHT im Release-ZIP (git archive --prefix=…).

# Dev-Lang-Packs (nur en/ bleibt im Release)
lang/de/                export-ignore
lang/de_du/             export-ignore
lang/de_formal/         export-ignore

# Tooling & CI
bin/                    export-ignore
.github/                export-ignore
.gitattributes          export-ignore
.gitignore              export-ignore

# Deploy-Artefakte und lokale Scratchfiles
.deploy/                export-ignore
deploy.sh               export-ignore
*.skill                 export-ignore

# Claude/Cowork Arbeits-Dokumente
CI_CD_KONZEPT.md        export-ignore
RESUME.md               export-ignore
.submission-draft.md    export-ignore

# Editor-Kram
.DS_Store               export-ignore
.idea/                  export-ignore
.vscode/                export-ignore
*.swp                   export-ignore
